{
  "name": "reamo",
  "private": false,
  "version": "1.0.0",
  "description": "A modern React-based web control surface for REAPER, designed for songwriting workflows",
  "type": "module",
  "scripts": {
    "prepare": "cd .. && husky frontend/.husky",
    "dev": "vite",
    "build": "tsc -b && vite build && cp ./dist/index.html ../reamo.html",
    "deploy": "npm run build && cp ./dist/index.html ../reamo.html",
    "release": "npm run deploy && node scripts/create-release-zip.js",
    "analyze": "tsc -b && vite build --mode analyze",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "cross-env NODE_OPTIONS=--no-webstorage vitest run",
    "test:watch": "cross-env NODE_OPTIONS=--no-webstorage vitest",
    "test:coverage": "cross-env NODE_OPTIONS=--no-webstorage vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.17",
    "@xstate/react": "^6.0.0",
    "lucide-react": "^0.559.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xstate": "^5.25.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.16",
    "ws": "^8.19.0"
  }
}
